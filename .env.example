# =====================================================
# Freezino Python API — Environment Variables
# =====================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ---- Application ----
ENVIRONMENT=production         # development | production
LOG_LEVEL=info                 # debug | info | warning | error

# ---- Security ----
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Database ----
# Inside docker container this is /app/data/freezino.db (see docker-compose.yml volumes).
# Locally without docker you can use ./freezino.db.
DB_PATH=/app/data/freezino.db

# ---- CORS ----
# Comma-separated list of allowed origins (no spaces).
CORS_ORIGINS=https://freezino.online

# ---- Frontend build args (used by docker-compose to pass to Vite build) ----
VITE_API_URL=https://freezino.online/api
VITE_GOOGLE_ENABLED=false
