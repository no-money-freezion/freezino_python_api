# Freezino frontend — Vite build-time environment variables.
# Copy to .env.local for dev, or pass as Docker ARGs in production build.

# Backend API base URL.
#   dev (local nginx on :8080): http://localhost:8080/api
#   dev (direct backend):       http://localhost:3000/api
#   prod (same-origin):         /api
VITE_API_URL=http://localhost:8080/api

# Show the Google OAuth button on the login page.
# Currently disabled — the Python API does not implement /api/auth/google yet.
# Flip to "true" once BE ships OAuth and bump FE-004 accordingly.
VITE_GOOGLE_ENABLED=false
